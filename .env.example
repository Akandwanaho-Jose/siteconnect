FIREBASE_PROJECT_ID=siteconnect-uganda
FIREBASE_SERVICE_ACCOUNT_FILE=tools/seed/credentials/service-account.json

# Existing Firebase Auth user to receive the first Firestore admin profile.
# Set either SEED_ADMIN_UID or SEED_ADMIN_EMAIL.
SEED_ADMIN_UID=
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_NAME=SiteConnect Administrator
SEED_ADMIN_PHONE=
SEED_ADMIN_DISTRICT=Kampala

# Optional existing Firebase Auth user to add as sample project manager.
SEED_SAMPLE_PROJECT_MANAGER_UID=
SEED_SAMPLE_PROJECT_DISTRICT=Kampala

# Optional dev/test login accounts for every role.
# These create Firebase Auth users and matching Firestore user profiles.
SEED_TEST_USERS=false
SEED_TEST_USERS_PASSWORD=SiteConnect@12345
SEED_TEST_USER_EMAIL_DOMAIN=siteconnect.test
SEED_TEST_USER_EMAIL_PREFIX=siteconnect
SEED_TEST_USER_DISTRICT=Kampala
